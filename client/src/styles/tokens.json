{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Fusiey design tokens. The visual language is pixel-art kawaii: a single plum outline on every surface, pastel fills, hard offset sticker shadows, chunky pixel typography. See docs/DESIGN_SYSTEM.md for usage rules.",
  "brand": {
    "name":        { "$type": "string", "$value": "Fusiey" },
    "tagline":     { "$type": "string", "$value": "AI-assisted perler-bead craft studio" },
    "productName": { "$type": "string", "$value": "Fusiey MARD-221 mini beads, 2.6mm" }
  },

  "color": {
    "ink": {
      "$description": "The single plum used as every outline stroke. Never replace with pure black.",
      "base": { "$type": "color", "$value": "#572C5F" },
      "deep": { "$type": "color", "$value": "#522756" },
      "soft": { "$type": "color", "$value": "#653366" },
      "hint": { "$type": "color", "$value": "#8F6A93" }
    },
    "surface": {
      "blush":      { "$type": "color", "$value": "#FCDFE5", "$description": "Default page background — cozy pink mist" },
      "blushSoft":  { "$type": "color", "$value": "#FDE1EC" },
      "blushDeep":  { "$type": "color", "$value": "#FAB3BB" },
      "paper":      { "$type": "color", "$value": "#FFFFFF" },
      "paperWarm":  { "$type": "color", "$value": "#FDF7F6", "$description": "Default card surface" },
      "cream":      { "$type": "color", "$value": "#FFF9F0", "$description": "Alt page bg for non-pink moods" }
    },
    "candy": {
      "$description": "The 5 sibling pastels that define every illustration. Each has a role; do not mix randomly.",
      "cotton":     { "$type": "color", "$value": "#F7A5B8", "$extensions": {"fusiey.role": "primary action / hot-pink accent"} },
      "cottonHi":   { "$type": "color", "$value": "#FEB0BF" },
      "peach":      { "$type": "color", "$value": "#FDC6A9", "$extensions": {"fusiey.role": "warm apricot / warning"} },
      "butter":     { "$type": "color", "$value": "#FFF4C0", "$extensions": {"fusiey.role": "highlight / :focus fill"} },
      "mint":       { "$type": "color", "$value": "#B8DFCA", "$extensions": {"fusiey.role": "success"} },
      "sky":        { "$type": "color", "$value": "#AFDCEB", "$extensions": {"fusiey.role": "info"} },
      "lilac":      { "$type": "color", "$value": "#E1B8DF", "$extensions": {"fusiey.role": "secondary decorative"} }
    },
    "semantic": {
      "fg":       { "primary":   { "$type": "color", "$value": "{color.ink.base}" },
                    "secondary": { "$type": "color", "$value": "{color.ink.soft}" },
                    "tertiary":  { "$type": "color", "$value": "{color.ink.hint}" },
                    "onInk":     { "$type": "color", "$value": "{color.surface.blush}" } },
      "bg":       { "page":      { "$type": "color", "$value": "{color.surface.blush}" },
                    "card":      { "$type": "color", "$value": "{color.surface.paperWarm}" },
                    "well":      { "$type": "color", "$value": "{color.surface.paper}" } },
      "accent":   { "default":   { "$type": "color", "$value": "{color.candy.cotton}" },
                    "hover":     { "$type": "color", "$value": "#EF95AA" },
                    "on":        { "$type": "color", "$value": "{color.ink.base}" } },
      "success":  { "$type": "color", "$value": "{color.candy.mint}" },
      "warning":  { "$type": "color", "$value": "{color.candy.peach}" },
      "info":     { "$type": "color", "$value": "{color.candy.sky}" },
      "highlight":{ "$type": "color", "$value": "{color.candy.butter}" },
      "border":   { "$type": "color", "$value": "{color.ink.base}", "$description": "ALWAYS plum. Never grey." },
      "borderSoft":{ "$type": "color", "$value": "#D8B9DB" }
    },

    "bead": {
      "$description": "MARD-221 official palette — the perler bead color codes customers physically own. Organized into 8 families (A–H). PALETTE_24 is the starter kit; PALETTE_48 is the extended set (24 basics + 24 additions). Use these exact codes on product pages, BOM tables, and anywhere a physical bead is referenced.",

      "A_yellow_orange": {
        "A4":  { "$type": "color", "$value": "#FFDC3A", "$extensions": {"fusiey.name": "yellow",        "fusiey.set": "24+48"} },
        "A6":  { "$type": "color", "$value": "#FF9A3A", "$extensions": {"fusiey.name": "orange",        "fusiey.set": "24+48"} },
        "A7":  { "$type": "color", "$value": "#E46A1A", "$extensions": {"fusiey.name": "dark orange",   "fusiey.set": "24+48"} },
        "A10": { "$type": "color", "$value": "#FFB34A", "$extensions": {"fusiey.name": "tangerine",     "fusiey.set": "48"} },
        "A11": { "$type": "color", "$value": "#FFD89A", "$extensions": {"fusiey.name": "peach yellow",  "fusiey.set": "48"} },
        "A13": { "$type": "color", "$value": "#F7B88A", "$extensions": {"fusiey.name": "apricot",       "fusiey.set": "48"} }
      },
      "B_green": {
        "B3":  { "$type": "color", "$value": "#B8E38E", "$extensions": {"fusiey.name": "light green",   "fusiey.set": "24+48"} },
        "B5":  { "$type": "color", "$value": "#5FB86A", "$extensions": {"fusiey.name": "green",         "fusiey.set": "24+48"} },
        "B8":  { "$type": "color", "$value": "#2E7A44", "$extensions": {"fusiey.name": "dark green",    "fusiey.set": "24+48"} },
        "B12": { "$type": "color", "$value": "#1B5534", "$extensions": {"fusiey.name": "forest green",  "fusiey.set": "48"} }
      },
      "C_cyan_blue": {
        "C2":  { "$type": "color", "$value": "#CDECED", "$extensions": {"fusiey.name": "pale cyan",     "fusiey.set": "48"} },
        "C3":  { "$type": "color", "$value": "#8DD4DD", "$extensions": {"fusiey.name": "cyan",          "fusiey.set": "24+48"} },
        "C5":  { "$type": "color", "$value": "#3E8BCB", "$extensions": {"fusiey.name": "blue",          "fusiey.set": "24+48"} },
        "C6":  { "$type": "color", "$value": "#A8D4F0", "$extensions": {"fusiey.name": "sky",           "fusiey.set": "48"} },
        "C7":  { "$type": "color", "$value": "#2A4FA8", "$extensions": {"fusiey.name": "royal",         "fusiey.set": "48"} },
        "C8":  { "$type": "color", "$value": "#13366E", "$extensions": {"fusiey.name": "dark blue",     "fusiey.set": "24+48"} },
        "C10": { "$type": "color", "$value": "#1A6D9E", "$extensions": {"fusiey.name": "ocean",         "fusiey.set": "48"} },
        "C11": { "$type": "color", "$value": "#4AB5B0", "$extensions": {"fusiey.name": "turquoise",     "fusiey.set": "48"} },
        "C13": { "$type": "color", "$value": "#E0F3F5", "$extensions": {"fusiey.name": "ice",           "fusiey.set": "48"} }
      },
      "D_purple": {
        "D3":  { "$type": "color", "$value": "#1E2858", "$extensions": {"fusiey.name": "navy",          "fusiey.set": "48"} },
        "D6":  { "$type": "color", "$value": "#C6B8E2", "$extensions": {"fusiey.name": "lavender",      "fusiey.set": "24+48"} },
        "D7":  { "$type": "color", "$value": "#8858B8", "$extensions": {"fusiey.name": "purple",        "fusiey.set": "24+48"} },
        "D9":  { "$type": "color", "$value": "#D6C1E8", "$extensions": {"fusiey.name": "light violet",  "fusiey.set": "24+48"} },
        "D13": { "$type": "color", "$value": "#C24098", "$extensions": {"fusiey.name": "magenta",       "fusiey.set": "48"} },
        "D15": { "$type": "color", "$value": "#4A3A8E", "$extensions": {"fusiey.name": "indigo",        "fusiey.set": "48"} },
        "D18": { "$type": "color", "$value": "#BE7FC3", "$extensions": {"fusiey.name": "orchid",        "fusiey.set": "48"} },
        "D19": { "$type": "color", "$value": "#E1B8DF", "$extensions": {"fusiey.name": "lilac",         "fusiey.set": "48"} },
        "D21": { "$type": "color", "$value": "#6E48A6", "$extensions": {"fusiey.name": "violet",        "fusiey.set": "48"} }
      },
      "E_pink": {
        "E2":  { "$type": "color", "$value": "#FCDFE5", "$extensions": {"fusiey.name": "light pink",    "fusiey.set": "24+48"} },
        "E3":  { "$type": "color", "$value": "#F3B3D4", "$extensions": {"fusiey.name": "orchid pink",   "fusiey.set": "48"} },
        "E4":  { "$type": "color", "$value": "#F58BB3", "$extensions": {"fusiey.name": "pink",          "fusiey.set": "24+48"} },
        "E7":  { "$type": "color", "$value": "#EF4A8E", "$extensions": {"fusiey.name": "hot pink",      "fusiey.set": "48"} },
        "E8":  { "$type": "color", "$value": "#FBC8D2", "$extensions": {"fusiey.name": "soft pink",     "fusiey.set": "48"} }
      },
      "F_red": {
        "F5":  { "$type": "color", "$value": "#E23A3A", "$extensions": {"fusiey.name": "red",           "fusiey.set": "24+48"} },
        "F8":  { "$type": "color", "$value": "#9E1E2A", "$extensions": {"fusiey.name": "dark red",      "fusiey.set": "48"} },
        "F13": { "$type": "color", "$value": "#F77878", "$extensions": {"fusiey.name": "coral",         "fusiey.set": "48"} }
      },
      "G_cream_brown": {
        "G1":  { "$type": "color", "$value": "#FFF4DC", "$extensions": {"fusiey.name": "cream",         "fusiey.set": "24+48"} },
        "G5":  { "$type": "color", "$value": "#D8A74A", "$extensions": {"fusiey.name": "gold",          "fusiey.set": "24+48"} },
        "G7":  { "$type": "color", "$value": "#8A5A36", "$extensions": {"fusiey.name": "brown",         "fusiey.set": "24+48"} },
        "G8":  { "$type": "color", "$value": "#5A3824", "$extensions": {"fusiey.name": "dark brown",    "fusiey.set": "48"} },
        "G9":  { "$type": "color", "$value": "#E6C89A", "$extensions": {"fusiey.name": "sand",          "fusiey.set": "48"} },
        "G13": { "$type": "color", "$value": "#A86B3E", "$extensions": {"fusiey.name": "chestnut",      "fusiey.set": "48"} }
      },
      "H_grayscale": {
        "H1":  { "$type": "color", "$value": "#FFFFFF", "$extensions": {"fusiey.name": "white",         "fusiey.set": "24+48"} },
        "H2":  { "$type": "color", "$value": "#E0DDE2", "$extensions": {"fusiey.name": "light grey",    "fusiey.set": "24+48"} },
        "H3":  { "$type": "color", "$value": "#B0ABB3", "$extensions": {"fusiey.name": "grey",          "fusiey.set": "24+48"} },
        "H4":  { "$type": "color", "$value": "#7C757E", "$extensions": {"fusiey.name": "medium grey",   "fusiey.set": "24+48"} },
        "H5":  { "$type": "color", "$value": "#46404A", "$extensions": {"fusiey.name": "dark grey",     "fusiey.set": "24+48"} },
        "H7":  { "$type": "color", "$value": "#1A0F1C", "$extensions": {"fusiey.name": "black",         "fusiey.set": "24+48"} }
      }
    }
  },

  "font": {
    "family": {
      "display": {
        "$type": "fontFamily",
        "$value": ["Press Start 2P", "ui-monospace", "monospace"],
        "$description": "Pixel font for the Fusiey wordmark and hero headlines. Use sparingly — heavy texture."
      },
      "pixel": {
        "$type": "fontFamily",
        "$value": ["Pixelify Sans", "Press Start 2P", "monospace"],
        "$description": "Softer pixel face for sub-headlines."
      },
      "body": {
        "$type": "fontFamily",
        "$value": ["Nunito", "-apple-system", "BlinkMacSystemFont", "Segoe UI", "system-ui", "sans-serif"],
        "$description": "Default UI + paragraph face. Round, warm, highly readable."
      },
      "cute": {
        "$type": "fontFamily",
        "$value": ["Fredoka", "Nunito", "sans-serif"],
        "$description": "Playful alt for sub-heads and UI labels."
      },
      "mono": {
        "$type": "fontFamily",
        "$value": ["VT323", "ui-monospace", "monospace"],
        "$description": "Pixel terminal. Use for tags, SKU codes, timestamps, numbers."
      }
    },
    "size": {
      "display": { "$type": "dimension", "$value": "40px" },
      "h1":      { "$type": "dimension", "$value": "32px" },
      "h2":      { "$type": "dimension", "$value": "24px" },
      "h3":      { "$type": "dimension", "$value": "20px" },
      "h4":      { "$type": "dimension", "$value": "16px" },
      "body":    { "$type": "dimension", "$value": "16px" },
      "small":   { "$type": "dimension", "$value": "14px" },
      "tiny":    { "$type": "dimension", "$value": "12px" },
      "mono":    { "$type": "dimension", "$value": "18px", "$description": "VT323 renders small at nominal px — bump it." }
    },
    "lineHeight": {
      "tight":  { "$type": "number", "$value": 1.15 },
      "snug":   { "$type": "number", "$value": 1.3 },
      "normal": { "$type": "number", "$value": 1.5 },
      "loose":  { "$type": "number", "$value": 1.7 }
    },
    "letterSpacing": {
      "display": { "$type": "dimension", "$value": "0.02em" },
      "body":    { "$type": "dimension", "$value": "0em" },
      "caps":    { "$type": "dimension", "$value": "0.08em" }
    },
    "weight": {
      "body":      { "$type": "number", "$value": 400 },
      "medium":    { "$type": "number", "$value": 500 },
      "semibold":  { "$type": "number", "$value": 600 },
      "bold":      { "$type": "number", "$value": 700 },
      "heavy":     { "$type": "number", "$value": 800 },
      "black":     { "$type": "number", "$value": 900 }
    }
  },

  "space": {
    "$description": "8pt grid with a 4pt half-step allowed at small sizes.",
    "0": { "$type": "dimension", "$value": "0px" },
    "1": { "$type": "dimension", "$value": "4px" },
    "2": { "$type": "dimension", "$value": "8px" },
    "3": { "$type": "dimension", "$value": "12px" },
    "4": { "$type": "dimension", "$value": "16px" },
    "5": { "$type": "dimension", "$value": "24px" },
    "6": { "$type": "dimension", "$value": "32px" },
    "7": { "$type": "dimension", "$value": "48px" },
    "8": { "$type": "dimension", "$value": "64px" },
    "9": { "$type": "dimension", "$value": "96px" }
  },

  "radius": {
    "$description": "Pixel-art surfaces stay square. Chrome (buttons, cards, inputs) uses gentle pill-ish corners.",
    "pixel": { "$type": "dimension", "$value": "0px",  "$description": "For bead cells, pixel art, anything meant to feel like a physical bead." },
    "sm":    { "$type": "dimension", "$value": "6px" },
    "md":    { "$type": "dimension", "$value": "10px" },
    "lg":    { "$type": "dimension", "$value": "16px", "$description": "Default card radius." },
    "xl":    { "$type": "dimension", "$value": "24px" },
    "pill":  { "$type": "dimension", "$value": "999px","$description": "Default button radius." }
  },

  "borderWidth": {
    "$description": "The plum outline is the defining visual element. 3px is canonical at 1:1.",
    "1": { "$type": "dimension", "$value": "2px" },
    "2": { "$type": "dimension", "$value": "3px", "$description": "Canonical stroke. Use on all cards, buttons, inputs." },
    "3": { "$type": "dimension", "$value": "4px" },
    "4": { "$type": "dimension", "$value": "6px", "$description": "For hero-scale surfaces only." }
  },

  "shadow": {
    "$description": "Shadows are NEVER blurred. Hard, offset plum rectangles — an extension of the outline. Sticker drop shadow.",
    "sticker":   { "$type": "shadow", "$value": { "offsetX": "3px", "offsetY": "3px", "blur": "0", "spread": "0", "color": "{color.ink.base}" }, "$description": "Default resting state for cards and buttons." },
    "stickerLg": { "$type": "shadow", "$value": { "offsetX": "6px", "offsetY": "6px", "blur": "0", "spread": "0", "color": "{color.ink.base}" } },
    "stickerHover": { "$type": "shadow", "$value": { "offsetX": "4px", "offsetY": "4px", "blur": "0", "spread": "0", "color": "{color.ink.base}" }, "$description": "On :hover, combine with translate(-1px,-1px) to lift the sticker." },
    "press":     { "$type": "shadow", "$value": { "offsetX": "1px", "offsetY": "1px", "blur": "0", "spread": "0", "color": "{color.ink.base}" }, "$description": "On :active, combine with translate(2px,2px) to press down." },
    "inset":     { "$type": "shadow", "$value": { "inset": true, "offsetX": "0", "offsetY": "0", "blur": "0", "spread": "3px", "color": "{color.ink.base}" } },
    "glowPink":  { "$type": "shadow", "$value": { "offsetX": "0", "offsetY": "0", "blur": "0", "spread": "6px", "color": "rgba(247,165,184,0.25)" }, "$description": "Soft pastel glow, used sparingly for dreamy moments." }
  },

  "motion": {
    "duration": {
      "fast": { "$type": "duration", "$value": "120ms" },
      "base": { "$type": "duration", "$value": "200ms" },
      "slow": { "$type": "duration", "$value": "360ms" }
    },
    "easing": {
      "bounce": { "$type": "cubicBezier", "$value": [0.34, 1.56, 0.64, 1], "$description": "Little boing — for button press, mascot wiggle, sticker lift." },
      "out":    { "$type": "cubicBezier", "$value": [0.22, 1, 0.36, 1] }
    }
  },

  "component": {
    "button": {
      "$description": "Pill button with plum outline + sticker shadow. Lifts on hover, presses on active.",
      "height":       { "$type": "dimension", "$value": "44px" },
      "heightSm":     { "$type": "dimension", "$value": "32px" },
      "heightLg":     { "$type": "dimension", "$value": "52px" },
      "paddingX":     { "$type": "dimension", "$value": "20px" },
      "radius":       { "$type": "dimension", "$value": "{radius.pill}" },
      "border":       { "$type": "dimension", "$value": "{borderWidth.2}" },
      "shadow":       { "$type": "shadow",    "$value": "{shadow.sticker}" },
      "fontFamily":   { "$type": "fontFamily","$value": "{font.family.cute}" },
      "fontWeight":   { "$type": "number",    "$value": 600 },
      "fontSize":     { "$type": "dimension", "$value": "{font.size.body}" }
    },
    "card": {
      "background":   { "$type": "color",     "$value": "{color.bg.well}" },
      "border":       { "$type": "dimension", "$value": "{borderWidth.2}" },
      "borderColor":  { "$type": "color",     "$value": "{color.ink.base}" },
      "radius":       { "$type": "dimension", "$value": "{radius.lg}" },
      "padding":      { "$type": "dimension", "$value": "{space.5}" },
      "shadow":       { "$type": "shadow",    "$value": "{shadow.sticker}" }
    },
    "input": {
      "height":       { "$type": "dimension", "$value": "44px" },
      "paddingX":     { "$type": "dimension", "$value": "14px" },
      "radius":       { "$type": "dimension", "$value": "{radius.md}" },
      "border":       { "$type": "dimension", "$value": "{borderWidth.2}" },
      "background":   { "$type": "color",     "$value": "{color.surface.paper}" },
      "backgroundFocus": { "$type": "color",  "$value": "{color.candy.butter}" },
      "fontFamily":   { "$type": "fontFamily","$value": "{font.family.body}" },
      "placeholder":  { "$type": "color",     "$value": "{color.ink.hint}" }
    },
    "tag": {
      "fontFamily":   { "$type": "fontFamily","$value": "{font.family.mono}" },
      "fontSize":     { "$type": "dimension", "$value": "{font.size.mono}" },
      "paddingX":     { "$type": "dimension", "$value": "8px" },
      "paddingY":     { "$type": "dimension", "$value": "3px" },
      "border":       { "$type": "dimension", "$value": "{borderWidth.1}" },
      "radius":       { "$type": "dimension", "$value": "{radius.sm}" },
      "background":   { "$type": "color",     "$value": "{color.candy.butter}" }
    }
  },

  "asset": {
    "logo": {
      "wordmark":   { "$type": "file", "$value": "/assets/fusiey-wordmark.svg" },
      "wordmarkPng":{ "$type": "file", "$value": "/assets/fusiey-wordmark.png" },
      "avatar":     { "$type": "file", "$value": "/assets/fusiey-avatar.svg" },
      "avatarPng":  { "$type": "file", "$value": "/assets/fusiey-avatar.png" }
    },
    "mascot": {
      "full":       { "$type": "file", "$value": "/assets/fusiey-mascot-full.svg", "$description": "Bunny mascot in hero pose." },
      "fullPng":    { "$type": "file", "$value": "/assets/fusiey-mascot-full.png" },
      "scene":      { "$type": "file", "$value": "/assets/fusiey-mascot-scene.svg", "$description": "Mascot in a context scene (workbench, bakery, etc.)." }
    }
  }
}
