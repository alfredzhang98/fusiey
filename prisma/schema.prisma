generator client {
  provider   = "prisma-client"
  output     = "../generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// User & Auth
// ============================================

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  name            String
  passwordHash    String?  // null = OAuth-only account (Google)
  googleId        String?  @unique
  emailVerified   Boolean  @default(false)
  role            Role     @default(CUSTOMER)
  // Credits: every new user gets 3 free generates. Decrements per AI call,
  // increments on publish / community points trade.
  generateCredits Int      @default(3)
  communityPoints Int      @default(0)
  // Used for auto-naming manual-drawn patterns ("drew bead 1", 2, 3, ...)
  namingCounter   Int      @default(0)
  avatarUrl       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders           Order[]
  savedPatterns    SavedPattern[]
  addresses        Address[]
  communityLikes   CommunityLike[]
  generateLogs     GenerateLog[]
  passwordResets   PasswordReset[]
  patternPurchases PatternPurchase[]

  @@map("users")
}

// ============================================
// Password reset — 6-digit code, hashed, short-lived
// ============================================

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String   // bcrypt hash of the 6-digit code (never stored in plain)
  // Timestamptz so the 10-minute window compares as an absolute instant,
  // immune to the DB session timezone (plain `timestamp` lost an hour in BST).
  expiresAt DateTime @db.Timestamptz(3)
  used      Boolean  @default(false)
  attempts  Int      @default(0) // wrong-code guesses; locked after 5
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("password_resets")
}

// ============================================
// Discount codes — homepage "10% off first kit" promo
// ============================================

model DiscountCode {
  id         String    @id @default(cuid())
  code       String    @unique
  email      String    // lowercased email the code was issued to
  percentOff Int       @default(10)
  campaign   String    @default("WELCOME") // tag for reporting / future promos
  used       Boolean   @default(false)
  usedAt     DateTime? @db.Timestamptz(3)
  orderId    String?   @unique // the order that redeemed it
  expiresAt  DateTime? @db.Timestamptz(3)
  createdAt  DateTime  @default(now()) @db.Timestamptz(3)

  @@index([email])
  @@map("discount_codes")
}

enum Role {
  CUSTOMER
  ADMIN
  SUPERADMIN
}

// ============================================
// Address (UK format)
// ============================================

model Address {
  id       String  @id @default(cuid())
  userId   String
  label    String  @default("Home")
  line1    String
  line2    String?
  city     String
  county   String?
  postcode String
  country  String  @default("GB")
  isDefault Boolean @default(false)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]

  @@map("addresses")
}

// ============================================
// Products
// ============================================

model Product {
  id                 String   @id @default(cuid())
  sku                String?  @unique
  name               String
  description        String
  // Per-region retail price (VAT-inclusive). GBP is required (UK home market +
  // the currency PayPal settles into). USD is optional — null means the product
  // is NOT sold in the US region. Prices are set manually per region, never
  // derived from an exchange rate.
  priceGBP           Decimal  @db.Decimal(10, 2)
  priceUSD           Decimal? @db.Decimal(10, 2)
  images             String[]
  category           String
  stock              Int      @default(0)
  lowStockThreshold  Int      @default(5)
  isCustomisable     Boolean  @default(false)
  isDigital          Boolean  @default(false)
  // Pattern (图纸) deliverables. Certified patterns carry an editable JSON that
  // is copied into the buyer's My Works on purchase; non-certified patterns
  // carry a downloadable file (PDF/PNG) the buyer downloads from My Works.
  isCertifiedPattern Boolean  @default(false)
  patternData        Json?    // certified: editable pattern { name,width,height,grid,paletteId,beadSize }
  patternFileUrl     String?  // non-certified: /uploads/patterns/... download
  patternFileType    String?  // 'pdf' | 'png'
  tags               String[]
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  orderItems OrderItem[]

  @@map("products")
}

// ============================================
// Orders
// ============================================

model Order {
  id              String      @id @default(cuid())
  userId          String
  status          OrderStatus @default(PENDING)
  // ── Accounting breakdown (all VAT-inclusive, GBP). totalAmount is the
  //    grand total charged: subtotal − discount + shipping. ──
  subtotalAmount  Decimal     @db.Decimal(10, 2) @default(0) // sum of line items
  discountAmount  Decimal     @db.Decimal(10, 2) @default(0) // money taken off
  discountCode    String?     // code applied at checkout, if any
  shippingAmount  Decimal     @db.Decimal(10, 2) @default(0)
  vatAmount       Decimal     @db.Decimal(10, 2) @default(0) // VAT portion of total
  totalAmount     Decimal     @db.Decimal(10, 2)
  currency        String      @default("GBP")
  shippingAddressId String?
  paymentMethod   String?
  paymentId       String?
  trackingNumber  String?
  carrier         String?
  trackingUrl     String?
  cancelReason    String?
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User        @relation(fields: [userId], references: [id])
  shippingAddress Address?    @relation(fields: [shippingAddressId], references: [id])
  items           OrderItem[]

  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model OrderItem {
  id            String  @id @default(cuid())
  orderId       String
  productId     String
  patternId     String?
  quantity      Int
  unitPrice     Decimal @db.Decimal(10, 2)
  customisation Json?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

// ============================================
// Saved Patterns (user designs)
// ============================================

model SavedPattern {
  id            String        @id @default(cuid())
  userId        String
  name          String
  width         Int
  height        Int
  grid          Json
  paletteId     String
  beadSize      Float         @default(5)
  thumbnail     String?
  source        PatternSource @default(AI)
  // Purchased certified ("official") patterns: an editable copy delivered into
  // the buyer's My Works. sourceProductId dedupes one copy per product.
  isPurchased     Boolean     @default(false)
  sourceProductId String?
  aiImageData   String?       // base64 of AI-stylised source (null for manual)
  stats         Json?         // { uniqueColors, greyRatio, islands, greyCount, ... }
  isPublished   Boolean       @default(false)
  publishedAt   DateTime?
  downloadCount Int           @default(0)
  likeCount     Int           @default(0)
  version       Int           @default(1)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes CommunityLike[]

  @@unique([userId, sourceProductId])
  @@index([isPublished, publishedAt(sort: Desc)])
  @@index([userId, updatedAt(sort: Desc)])
  @@map("saved_patterns")
}

enum PatternSource {
  AI
  MANUAL
  OFFICIAL
}

// ============================================
// Community
// ============================================

model CommunityLike {
  id        String   @id @default(cuid())
  userId    String
  patternId String
  createdAt DateTime @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  pattern SavedPattern @relation(fields: [patternId], references: [id], onDelete: Cascade)

  @@unique([userId, patternId])
  @@map("community_likes")
}

// ============================================
// Generate log — audit trail for AI calls + credit mutations
// ============================================

model GenerateLog {
  id         String       @id @default(cuid())
  userId     String
  kind       GenerateKind
  creditCost Int          // -1 AI, -10 points trade, +1 publish reward, etc.
  success    Boolean      @default(true)
  errorMsg   String?
  durationMs Int?
  createdAt  DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([createdAt])
  @@map("generate_logs")
}

enum GenerateKind {
  AI_STYLIZE
  AI_ANALYZE
  AI_EVALUATE
  AI_GENERATE_IMAGE
  POINTS_TRADE
  PUBLISH_REWARD
  ADMIN_ADJUST
}

// ============================================
// Site Config (admin-managed)
// ============================================

model SiteConfig {
  id    String @id @default(cuid())
  key   String @unique
  value Json

  @@map("site_config")
}

// ============================================
// Media Library (admin-managed product images)
// ============================================
// Structured, non-flat storage: category → product folder (code + name) →
// image assets. Files live on disk under UPLOAD_DIR; rows hold metadata + the
// public relative URL.

model MediaFolder {
  id        String       @id @default(cuid())
  category  String        // one of the 5 product category keys
  code      String        // 商品编号
  name      String        // 商品名称
  createdAt DateTime     @default(now())

  assets MediaAsset[]

  @@unique([category, code])
  @@map("media_folders")
}

model MediaAsset {
  id        String   @id @default(cuid())
  folderId  String
  url       String   // relative "/uploads/products/<category>/<code>/<file>"
  filename  String
  mime      String
  size      Int
  width     Int?
  height    Int?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  folder MediaFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@index([folderId])
  @@map("media_assets")
}

// ============================================
// Pattern purchases — non-certified (download) pattern deliverables
// ============================================
// Certified patterns deliver an editable SavedPattern copy; non-certified
// pattern products deliver a downloadable file (PDF/PNG) recorded here and
// shown in the buyer's My Works.

model PatternPurchase {
  id        String   @id @default(cuid())
  userId    String
  productId String
  name      String
  fileUrl   String   // /uploads/patterns/...
  fileType  String   // 'pdf' | 'png'
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("pattern_purchases")
}
