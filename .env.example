# App Configuration
APP_URL="http://localhost:3000"
NODE_ENV="development"
PORT=3000

# PostgreSQL Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fusiey?schema=public"

# Payment - Stripe (Phase 5)
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# Payment - PayPal Standard Checkout
# Create REST API credentials at https://developer.paypal.com/dashboard/applications
# Use sandbox keys for testing; switch PAYPAL_MODE to "live" with live keys for production.
PAYPAL_MODE="sandbox"
PAYPAL_CLIENT_ID="your-paypal-client-id"
PAYPAL_SECRET="your-paypal-secret"
VITE_PAYPAL_CLIENT_ID="your-paypal-client-id"

# JWT Auth Secrets — used to sign access (15min) and refresh (30d) tokens.
# Generate strong random strings for production:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET="your_access_secret_here"
JWT_REFRESH_SECRET="your_refresh_secret_here"

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# 1. Create an OAuth 2.0 Client ID for a Web application
# 2. Add http://localhost:3000 to Authorized JavaScript origins
# 3. Copy the Client ID below (same value for both vars)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
VITE_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# ── AI (feature archived — see archive/ai/README.md to re-integrate) ──
# GEMINI_API_KEY="your_gemini_api_key_here"
# REPLICATE_API_TOKEN="your_replicate_token_here"
